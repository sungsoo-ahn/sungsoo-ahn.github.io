{% assign series_posts = site.posts | where: "series", page.series | sort: "series_order" %}
{% if page.series and series_posts.size > 1 %}
  <nav class="series-nav" aria-label="Series navigation">
    <p class="series-eyebrow">Reading path</p>
    <h2>{{ page.series_title | default: page.series | replace: "-", " " | capitalize }}</h2>
    {% if page.series_description %}
      <p class="series-description">{{ page.series_description }}</p>
    {% endif %}
    <ol>
      {% for post in series_posts %}
        <li class="{% if post.url == page.url %}current{% endif %}">
          {% if post.url == page.url %}
            <span aria-current="page">{{ post.title }}</span>
          {% else %}
            <a href="{{ post.url | relative_url }}">{{ post.title }}</a>
          {% endif %}
        </li>
      {% endfor %}
    </ol>
  </nav>
{% endif %}
